# ============================================
# SecureLLM On-Premise Configuration
# ============================================

# Redis (local, managed by Docker Compose)
REDIS_URL=redis://redis:6379/0

# Auth - auto-generated during install
API_SECRET_KEY=change-me-to-a-random-64-char-string
ADMIN_API_KEY=change-me-admin-key

# Presidio (leave empty for built-in engine)
PRESIDIO_EXTERNAL_URL=

# Server
HOST=0.0.0.0
PORT=8000

# === On-Premise Settings ===
DEPLOYMENT_MODE=onprem
LICENSE_KEY=
SAAS_URL=https://securellm.railway.app
INSTANCE_ID=

# === NATS Tunnel (connects to Railway SaaS) ===
WORKSPACE_ID=
SAAS_NATS_URL=wss://securellm.railway.app:443/nats
LOCAL_NATS_TOKEN=auto-generated
NATS_CREDENTIALS=
ENGINE_URL=http://engine:8000
NATS_URL=nats://nats-leaf:4222
HEARTBEAT_INTERVAL=30
ENGINE_VERSION=1.0.0
